From 9f97d1960122a17a4d2abc4f2aa7da6c73bc0ee4 Mon Sep 17 00:00:00 2001
From: Verge Build Fix <buildfix@local>
Date: Tue, 3 Mar 2026 00:00:00 +0000
Subject: [PATCH] qtbase: guard newer Windows net symbols for older MinGW

Older MinGW32 header sets used in Ubuntu 22.04 can miss a subset of newer
Windows networking and DNS members used by Qt 6.10.2. Guard those uses so the
Qt Network build still succeeds when those symbols are unavailable.
---
--- a/qtbase/src/network/kernel/qdnslookup_win.cpp	2026-01-13 05:18:17.000000000 -0500
+++ b/qtbase/src/network/kernel/qdnslookup_win.cpp	2026-03-03 14:03:45.453702226 -0500
@@ -94,7 +94,11 @@
     }
 
     // set AD bit: we want to trust this server
+#if defined(__MINGW32__) && !defined(DNS_ADDR_MAX_SOCKADDR_LENGTH)
+    // Older MinGW DNS headers do not expose this bitfield.
+#else
     dnsBuffer->MessageHead.AuthenticatedData = true;
+#endif
 
     QDnsLookupRunnable::ReplyBuffer replyBuffer;
     if (!self->sendDnsOverTls(reply, { query.data(), qsizetype(dnsBufferSize) }, replyBuffer))
@@ -225,6 +229,7 @@
             record.d->timeToLive = ptr->dwTtl;
             record.d->weight = ptr->Data.Srv.wWeight;
             reply->serviceRecords.append(record);
+#if !(defined(__MINGW32__) && !defined(DNS_ADDR_MAX_SOCKADDR_LENGTH))
         } else if (ptr->wType == QDnsLookup::TLSA) {
             // Note: untested, because the DNS_RECORD reply appears to contain
             // no records relating to TLSA. Maybe WinDNS filters them out of
@@ -244,6 +249,7 @@
             record.d->value.assign(tlsa.bCertificateAssociationData,
                                    tlsa.bCertificateAssociationData + tlsa.bCertificateAssociationDataLength);
             reply->tlsAssociationRecords.append(std::move(record));
+#endif
         } else if (ptr->wType == QDnsLookup::TXT) {
             QDnsTextRecord record;
             record.d->name = name;
--- a/qtbase/src/network/socket/qnativesocketengine_win.cpp	2026-01-13 05:18:17.000000000 -0500
+++ b/qtbase/src/network/socket/qnativesocketengine_win.cpp	2026-03-03 14:03:45.448463435 -0500
@@ -477,10 +477,12 @@
             // IPv4 - uses network byte order
             int netIdx = htonl(v);
             // Bind outgoing datagrams to the interface
+#if defined(IP_UNICAST_IF)
             if (!ret) {
                 ret = ::setsockopt(socketDescriptor, IPPROTO_IP, IP_UNICAST_IF,
                                    reinterpret_cast<char *>(&netIdx), sizeof(netIdx));
             }
+#endif
             if (!ret) {
                 ret = ::setsockopt(socketDescriptor, IPPROTO_IP, IP_MULTICAST_IF,
                                    reinterpret_cast<char *>(&netIdx), sizeof(netIdx));
@@ -488,6 +490,7 @@
             // Bind incoming datagrams to the interface
             if (!ret) {
                 const int enable = 1;
+#if defined(IP_IFLIST) && defined(IP_ADD_IFLIST)
                 ret = ::setsockopt(socketDescriptor, IPPROTO_IP, IP_IFLIST,
                                    reinterpret_cast<const char *>(&enable), sizeof(enable));
                 if (!ret) {
@@ -495,6 +498,7 @@
                     ret = ::setsockopt(socketDescriptor, IPPROTO_IP, IP_ADD_IFLIST,
                                        reinterpret_cast<char *>(&v), sizeof(v));
                 }
+#endif
             }
             if (socketProtocol == QAbstractSocket::IPv4Protocol)
                 result = !ret;
-- 
